# ElectricityMaps free-tier API key: https://portal.electricitymaps.com/
ELECTRICITYMAPS_API_KEY=

# Optional: enables the LLM agent's natural-language parsing. Without it,
# the agent falls back to a regex-based parser for the workload text box.
ANTHROPIC_API_KEY=

# Shared secret the GPU poller must send in the X-Ingest-Key header.
INGEST_SHARED_SECRET=dev-secret-change-me

# Comma-separated list of allowed CORS origins for the frontend dev server.
CORS_ORIGINS=http://localhost:5173
